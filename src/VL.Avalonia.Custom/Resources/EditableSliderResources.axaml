<ResourceDictionary xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:local="clr-namespace:VL.Avalonia.Custom.Controls.Value">

  <Design.PreviewWith>
    <local:EditableSlider Width="300" Height="50"/>
  </Design.PreviewWith>

  <x:Double x:Key="SliderHorizontalHeight">32</x:Double>
  
  <ControlTheme x:Key="EditableSliderHorizontalRepeatButtonDecrease" TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="borderDecrease" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">

        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="EditableSliderHorizontalRepeatButtonIncrease" TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="borderIncrease" Background="{TemplateBinding Background}" CornerRadius="0"/>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
  
  <ControlTheme x:Key="{x:Type local:EditableSlider}" TargetType="Slider">
    <Setter Property="Background" Value="{DynamicResource SliderTrackFill}" />
    <Setter Property="BorderThickness" Value="{DynamicResource SliderBorderThemeThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource SliderTrackValueFill}" />
    <Setter Property="Minimum" Value="0"/>
    <Setter Property="Maximum" Value="1.00"/>
    
    <Style Selector="^:horizontal">
      <Setter Property="Template">
        <ControlTemplate>
          <DataValidationErrors>
            <Border
              x:Name="PART_MainBorder"
              Background="Transparent"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}">
              
              <Grid Margin="{TemplateBinding Padding}"
                    Background="{DynamicResource SliderContainerBackground}">
                <Border x:Name="borderMask"
                          Background="Black"
                          CornerRadius="{TemplateBinding CornerRadius}"/>

                <Border MinHeight="{DynamicResource SliderHorizontalHeight}">
                  <Border.OpacityMask>
                    <VisualBrush Stretch="Fill" Opacity="1" Visual="{Binding ElementName=borderMask}"/>
                  </Border.OpacityMask>
                  <Track
                      Name="PART_Track"
                      Minimum="{TemplateBinding Minimum}"
                      Maximum="{TemplateBinding Maximum}"
                      Value="{TemplateBinding Value, Mode=TwoWay}"
                      IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                      Orientation="Horizontal">

                    <Track.DecreaseButton>
                      <RepeatButton
                          Name="PART_DecreaseButton"
                          VerticalAlignment="Stretch"
                          Theme="{StaticResource EditableSliderHorizontalRepeatButtonDecrease}"
                          Background="{DynamicResource SystemControlForegroundAccentBrush}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.DecreaseButton>
                    
                    <Track.IncreaseButton>
                      <RepeatButton
                          Name="PART_IncreaseButton"
                          Theme="{StaticResource EditableSliderHorizontalRepeatButtonIncrease}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.IncreaseButton>

                  </Track>
                </Border>

                <TextBox
                    x:Name="textInput"
                    Height="{Binding $parent[local:EditableSlider].ActualHeight}"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Left"
                    Padding="8, 0, 0, 0"
                    Text="{Binding $parent[local:EditableSlider].Value, StringFormat='{}{0:F3}'}" 
                    IsVisible="{Binding $parent[local:EditableSlider].IsEditing}">
                  
                  <TextBox.Styles>
                    
                    <Style Selector="TextBox">
                      <Setter Property="ContextFlyout" Value="{x:Null}" />
                    </Style>

                    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                      <Setter Property="CornerRadius" Value="{Binding $parent[local:EditableSlider].CornerRadius}"/>
                    </Style>
                    
                  </TextBox.Styles>

                </TextBox>

                <TextBlock
                   Padding="8,0"
                   Foreground="{DynamicResource SystemChromeWhiteColor}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   IsVisible="{Binding !$parent[local:EditableSlider].IsEditing}"
                   Text="{Binding $parent[local:EditableSlider].Value, StringFormat='{}{0:F3}'}" />
                
                <TextBlock
                  Padding="8,0"
                  Foreground="{DynamicResource SystemChromeWhiteColor}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False"
                  IsVisible="{Binding !$parent[local:EditableSlider].IsEditing}"
                  Text="{Binding $parent[local:EditableSlider].Name}" />

              </Grid>
            </Border>
          </DataValidationErrors>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="^:vertical">
      <Setter Property="Template">
        <ControlTemplate>
          <DataValidationErrors>
            <Border
              x:Name="PART_MainBorder"
              Background="Transparent"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}">

              <Grid Margin="{TemplateBinding Padding}"
                    Background="{DynamicResource SliderContainerBackground}">
                <Border x:Name="borderMask"
                          Background="Black"
                          CornerRadius="{TemplateBinding CornerRadius}"/>

                <Border MinWidth="{DynamicResource SliderVerticalWidth}">
                  <Border.OpacityMask>
                    <VisualBrush Stretch="Fill" Opacity="1" Visual="{Binding ElementName=borderMask}"/>
                  </Border.OpacityMask>
                  <Track
                      Name="PART_Track"
                      Minimum="{TemplateBinding Minimum}"
                      Maximum="{TemplateBinding Maximum}"
                      Value="{TemplateBinding Value, Mode=TwoWay}"
                      IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                      Orientation="Vertical">

                    <Track.DecreaseButton>
                      <RepeatButton
                          Name="PART_DecreaseButton"
                          VerticalAlignment="Stretch"
                          Theme="{StaticResource TemplatedSliderVerticalRepeatButtonDecrease}"
                          Background="{DynamicResource SystemControlForegroundAccentBrush}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.DecreaseButton>

                    <Track.IncreaseButton>
                      <RepeatButton
                          Name="PART_IncreaseButton"
                          Theme="{StaticResource TemplatedSliderVerticalRepeatButtonIncrease}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.IncreaseButton>

                  </Track>
                </Border>

                <TextBox
                    x:Name="textInput"
                    Height="{Binding $parent[local:EditableSlider].ActualHeight}"
                    VerticalContentAlignment="Bottom"
                    HorizontalContentAlignment="Center"
                    Padding="0, 0, 0, 8"
                    Text="{Binding $parent[local:EditableSlider].Value, StringFormat='{}{0:F3}'}"
                    IsVisible="{Binding $parent[local:EditableSlider].IsEditing}">

                  <TextBox.Styles>

                    <Style Selector="TextBox">
                      <Setter Property="ContextFlyout" Value="{x:Null}" />
                    </Style>

                    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                      <Setter Property="CornerRadius" Value="{Binding $parent[local:EditableSlider].CornerRadius}"/>
                    </Style>

                  </TextBox.Styles>

                </TextBox>

                <TextBlock
                   Padding="0,8"
                   Foreground="{DynamicResource SystemChromeWhiteColor}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   IsHitTestVisible="False"
                   IsVisible="{Binding !$parent[local:EditableSlider].IsEditing}"
                   Text="{Binding $parent[local:EditableSlider].Value, StringFormat='{}{0:F3}'}" />

                <TextBlock
                  Padding="0,8"
                  Foreground="{DynamicResource SystemChromeWhiteColor}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  IsVisible="{Binding !$parent[local:EditableSlider].IsEditing}"
                  Text="{Binding $parent[local:EditableSlider].Name}" />


              </Grid>
            </Border>
          </DataValidationErrors>
        </ControlTemplate>
      </Setter>
    </Style>
    
    <Style Selector="^:pointerover">

      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight1}"/>
      </Style>

      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemChromeMediumColor}"/>
      </Style>

    </Style>

    <Style Selector="^:pressed">

      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}"/>
      </Style>

      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemChromeLowColor}"/>
      </Style>

    </Style>

    <Style Selector="^:disabled">

      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemControlDisabledChromeDisabledHighBrush}" />
      </Style>

      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SystemControlDisabledChromeDisabledHighBrush}" />
      </Style>

      <Style Selector="^:error">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlErrorTextForegroundBrush}" />
      </Style>

    </Style>
    
  </ControlTheme>
</ResourceDictionary>


