<ResourceDictionary xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:local="clr-namespace:VL.Avalonia.Custom.Controls"
                    xmlns:conv="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
                    xmlns:converter="clr-namespace:ClassLibrary1.Converters;assembly=ClassLibrary1">

  <Design.PreviewWith>
    <local:TemplatableSlider Width="300" Height="50"/>
  </Design.PreviewWith>

  <ControlTheme x:Key="TemplatableSliderHorizontalRepeatButtonDecrease" TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="borderDecrease" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">

        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="TemplatableSliderHorizontalRepeatButtonIncrease" TargetType="RepeatButton">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="borderIncrease" Background="{TemplateBinding Background}" CornerRadius="0"/>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
  
  <ControlTheme x:Key="{x:Type local:TemplatableSlider}" TargetType="Slider">
    <Setter Property="Background" Value="{DynamicResource SliderTrackFill}" />
    <Setter Property="BorderThickness" Value="{DynamicResource SliderBorderThemeThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource SliderTrackValueFill}" />
    <Style Selector="^:horizontal">
      <Setter Property="Template">
        <ControlTemplate>
          <DataValidationErrors>
            <Border
              x:Name="PART_MainBorder"
              Background="Transparent"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}">
              
              <Grid Margin="{TemplateBinding Padding}"
                    Background="{DynamicResource SliderContainerBackground}">
                <Border x:Name="borderMask"
                          Background="Black"
                          CornerRadius="{TemplateBinding CornerRadius}"/>

                <Border>
                  <Border.OpacityMask>
                    <VisualBrush Stretch="Fill" Opacity="1" Visual="{Binding ElementName=borderMask}"/>
                  </Border.OpacityMask>
                  <Track
                      Name="PART_Track"
                      Minimum="{TemplateBinding Minimum}"
                      Maximum="{TemplateBinding Maximum}"
                      Value="{TemplateBinding Value, Mode=TwoWay}"
                      IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                      Orientation="Horizontal">

                    <Track.DecreaseButton>
                      <RepeatButton
                          Name="PART_DecreaseButton"
                          VerticalAlignment="Stretch"
                          Theme="{StaticResource TemplatableSliderHorizontalRepeatButtonDecrease}"
                          Background="{DynamicResource SystemControlForegroundAccentBrush}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.DecreaseButton>
                    
                    <Track.IncreaseButton>
                      <RepeatButton
                          Name="PART_IncreaseButton"
                          Theme="{StaticResource TemplatableSliderHorizontalRepeatButtonIncrease}"
                          Background="{DynamicResource SliderTrackFill}"
                          HorizontalAlignment="Stretch"
                          Focusable="False"/>
                    </Track.IncreaseButton>

                  </Track>
                </Border>

                <ContentPresenter Content="{Binding $parent[local:TemplatableSlider].Content}"/>


              </Grid>
            </Border>
          </DataValidationErrors>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="^:pointerover">
      
      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderThumbBackgroundPointerOver}"/>
      </Style>
      
      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderTrackFillPointerOver}"/>
      </Style>
      
    </Style>

    <Style Selector="^:pressed">
      
      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderThumbBackgroundPressed}"/>
      </Style>
      
      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderTrackFillPressed}"/>
      </Style>
      
    </Style>

    <Style Selector="^:disabled">
      
      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderTrackValueFillDisabled}" />
      </Style>

      <Style Selector="^ /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource SliderTrackFillDisabled}" />
      </Style>

      <Style Selector="^:error">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlErrorTextForegroundBrush}" />
      </Style>
      
    </Style>
  </ControlTheme>
</ResourceDictionary>


